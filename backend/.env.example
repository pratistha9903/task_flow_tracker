# ─── Supabase (PostgreSQL) ───
# Get from: Supabase Dashboard → Connect (or Settings → Database → Connection string → URI)

# Runtime API — Transaction pooler (port 6543). REQUIRED: ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migrations / db push
# LOCAL: can use direct OR session pooler
# RENDER/DEPLOY: MUST use Session pooler (port 5432 on pooler host) — NOT db.xxx.supabase.co (IPv6 only)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Encode special chars in password: @ → %40  # → %23

JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="24h"
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Deploy guide: docs/DEPLOY-RENDER.md
